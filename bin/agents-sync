#!/usr/bin/env python3
"""agents-sync — hydrate project-root AGENTS.md with the shared-doctrine block
from the canonical file (~/.dotfiles/agents/AGENTS.md).

Only content between the BEGIN/END markers is managed; project-specific content
outside the markers is preserved. No merge, no dedup — block replace. Idempotent.

Usage:
  agents-sync [ROOT]     hydrate every git repo directly under ROOT (default ~/Projects)
  agents-sync --here     hydrate only the repo containing the current directory
  agents-sync --dry-run  show what would change without writing (works with either mode)
"""
import os, re, sys, glob, subprocess

HERE = os.path.dirname(os.path.realpath(__file__))
DEFAULT_CANON = os.path.normpath(os.path.join(HERE, "..", "agents", "AGENTS.md"))
CANON = os.environ.get("AGENTS_CANON", DEFAULT_CANON)

flags = {a for a in sys.argv[1:] if a.startswith("--")}
pos = [a for a in sys.argv[1:] if not a.startswith("--")]
DRY = "--dry-run" in flags
HERE_MODE = "--here" in flags

BEGIN = "<!-- BEGIN shared-doctrine: synced from ~/.dotfiles/agents/AGENTS.md — edit there, run agents-sync -->"
END = "<!-- END shared-doctrine -->"
EXCLUDE = {"vault", "dotfiles"}

if not os.path.isfile(CANON):
    sys.exit(f"canonical doctrine not found: {CANON}")
doctrine = open(CANON, encoding="utf-8").read().strip()
block = f"{BEGIN}\n\n{doctrine}\n\n{END}"

def hydrate(repo):
    f = os.path.join(repo, "AGENTS.md")
    old = open(f, encoding="utf-8").read() if os.path.isfile(f) else None
    if old is None:
        new = block + "\n"
    elif BEGIN in old and END in old:
        new = re.sub(re.escape(BEGIN) + ".*?" + re.escape(END), lambda _: block, old, flags=re.S)
    else:
        new = block + "\n\n" + old
    if new != old:
        print(("would sync: " if DRY else "synced: ") + f)
        if not DRY:
            open(f, "w", encoding="utf-8").write(new)
        return 1
    return 0

changed = 0
if HERE_MODE:
    try:
        root = subprocess.check_output(["git", "rev-parse", "--show-toplevel"],
                                       stderr=subprocess.DEVNULL, text=True).strip()
    except subprocess.CalledProcessError:
        sys.exit("not inside a git repo")
    changed += hydrate(root)
    print(f"\n{changed} file(s) {'would be ' if DRY else ''}updated  ({root})")
else:
    root = os.path.expanduser(pos[0]) if pos else os.path.expanduser("~/Projects")
    for git in sorted(glob.glob(os.path.join(root, "*", ".git"))):
        repo = os.path.dirname(git)
        if os.path.basename(repo) in EXCLUDE:
            continue
        changed += hydrate(repo)
    print(f"\n{changed} file(s) {'would be ' if DRY else ''}updated  (root: {root})")
