#!/usr/bin/env python3
"""agents-sync — hydrate each project-root AGENTS.md with the shared-doctrine
block from the canonical file (~/.dotfiles/agents/AGENTS.md).

Only the content between the BEGIN/END markers is managed; any project-specific
content outside the markers is preserved. No merge, no dedup — block replace.
Idempotent. Safe to re-run.

Usage:
  agents-sync [ROOT] [--dry-run]
    ROOT       parent dir to scan for git repos (default: ~/Projects)
    --dry-run  show what would change without writing
"""
import os, re, sys, glob

HERE = os.path.dirname(os.path.realpath(__file__))
DEFAULT_CANON = os.path.normpath(os.path.join(HERE, "..", "agents", "AGENTS.md"))
CANON = os.environ.get("AGENTS_CANON", DEFAULT_CANON)

args = [a for a in sys.argv[1:] if a != "--dry-run"]
ROOT = os.path.expanduser(args[0]) if args else os.path.expanduser("~/Projects")
DRY = "--dry-run" in sys.argv

BEGIN = "<!-- BEGIN shared-doctrine: synced from ~/.dotfiles/agents/AGENTS.md — edit there, run agents-sync -->"
END = "<!-- END shared-doctrine -->"

# repo basenames to skip (not code projects, or the canonical's own home)
EXCLUDE = {"vault", "dotfiles"}

if not os.path.isfile(CANON):
    sys.exit(f"canonical doctrine not found: {CANON}")

doctrine = open(CANON, encoding="utf-8").read().strip()
block = f"{BEGIN}\n\n{doctrine}\n\n{END}"

changed = 0
for git in sorted(glob.glob(os.path.join(ROOT, "*", ".git"))):
    repo = os.path.dirname(git)
    if os.path.basename(repo) in EXCLUDE:
        continue
    f = os.path.join(repo, "AGENTS.md")
    old = open(f, encoding="utf-8").read() if os.path.isfile(f) else None
    if old is None:
        new = block + "\n"
    elif BEGIN in old and END in old:
        new = re.sub(re.escape(BEGIN) + ".*?" + re.escape(END),
                     lambda _: block, old, flags=re.S)
    else:
        new = block + "\n\n" + old
    if new != old:
        changed += 1
        print(("would sync: " if DRY else "synced: ") + f)
        if not DRY:
            open(f, "w", encoding="utf-8").write(new)

print(f"\n{changed} file(s) {'would be ' if DRY else ''}updated  (root: {ROOT})")
